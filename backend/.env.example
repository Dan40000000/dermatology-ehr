##############################################
# Core Runtime
##############################################
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173
TENANT_HEADER=x-tenant-id

##############################################
# Database (production should enforce TLS)
##############################################
DATABASE_URL=postgres://derm_user:derm_pass@localhost:5432/derm_db
DB_PASSWORD=derm_pass
DB_SSL_ENABLED=false
DB_SSL_REJECT_UNAUTHORIZED=true

##############################################
# Security / Auth
# NOTE: In production, use 32+ char secrets
##############################################
JWT_SECRET=replace-with-32-plus-char-secret
JWT_ISSUER=derm-app
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=1209600
SESSION_SECRET=replace-with-32-plus-char-secret
CSRF_SECRET=replace-with-32-plus-char-secret
ENCRYPTION_KEY=replace-with-32-plus-char-secret
PHI_ENCRYPTION_ENABLED=false
DEFAULT_USER_PASSWORD=your-secure-default-password

##############################################
# CORS / Surface Hardening
##############################################
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true
ENABLE_API_DOCS=true
ENABLE_PLAYGROUND=false

##############################################
# Storage
##############################################
STORAGE_PROVIDER=s3
AWS_S3_BUCKET=your-bucket
AWS_REGION=us-east-1
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

##############################################
# Monitoring / Ops
# SENTRY_DSN is recommended for production.
##############################################
SENTRY_DSN=
AUDIT_LOG_RETENTION_DAYS=2555
BACKUP_ENABLED=false
BACKUP_BUCKET=
VIRUS_SCAN_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=4000
INIT_SECRET=

##############################################
# Twilio SMS (optional)
##############################################
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_STATUS_CALLBACK_URL=
TWILIO_A2P_CONTACT_EMAIL=

##############################################
# Stripe (optional; test keys first)
##############################################
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

##############################################
# Phaxio Fax (optional)
##############################################
PHAXIO_API_KEY=
PHAXIO_API_SECRET=
PHAXIO_FROM_NUMBER=
PHAXIO_BASE_URL=https://api.phaxio.com/v2

##############################################
# Feature Flags
##############################################
ENABLE_EMAIL_DELIVERY=false
EMAIL_NOTIFICATION_ONLY=true

##############################################
# Email Transport (SMTP or SES)
# Set ENABLE_EMAIL_DELIVERY=true only after credentials are valid.
##############################################
FROM_EMAIL=dan@perrysoftwarellc.com
FROM_NAME=Dermatology Program
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
# Twilio SendGrid SMTP aliases (optional)
# If SMTP_USER is empty and host contains "sendgrid", app defaults user to "apikey".
SENDGRID_SMTP_HOST=smtp.sendgrid.net
SENDGRID_SMTP_USERNAME=apikey
SENDGRID_SMTP_API_KEY=
TWILIO_SENDGRID_API_KEY=

##############################################
# Healthcare workflow vendor scaffolding
# Real vendor adapters can replace these mock transports after contracting.
##############################################
ELIGIBILITY_PROVIDER=stedi
STEDI_API_KEY=
STEDI_API_BASE_URL=https://healthcare.us.stedi.com/2024-04-01
STEDI_ELIGIBILITY_PATH=/change/medicalnetwork/eligibility/v3
PRESCRIBING_PROVIDER=mock
PRIOR_AUTH_PROVIDER=mock

##############################################
# Ambient AI (optional; falls back to mock)
##############################################
OPENAI_API_KEY=
OPENAI_API_CALLS_ENABLED=false
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe-diarize
OPENAI_NOTE_MODEL=gpt-4o
OPENAI_COPILOT_MODEL=gpt-4o
OPENAI_LIVE_INSIGHTS_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_API_CALLS_ENABLED=false
EXTERNAL_AI_API_CALLS_ENABLED=false
ALLOW_EXTERNAL_AI_IN_TEST=false
ANTHROPIC_NOTE_MODEL=claude-3-5-sonnet-20241022
AMBIENT_LIVE_TRANSCRIBE_ENABLED=true
AMBIENT_LIVE_TRANSCRIBE_MIN_INTERVAL_MS=5000
AMBIENT_LIVE_TRANSCRIBE_MODEL=gpt-4o-transcribe
AMBIENT_LIVE_AI_ENABLED=false
AMBIENT_LIVE_AI_MIN_INTERVAL_MS=15000
AMBIENT_LIVE_AI_MIN_CHARS=180
AMBIENT_LIVE_AI_MIN_DELTA_CHARS=80

##############################################
# Ambient transcription provider (optional)
# Set to one of: abridge, nabla, aws_healthscribe, wispr_flow
# If omitted, the app auto-detects based on which provider credentials are present.
##############################################
AMBIENT_TRANSCRIPTION_PROVIDER=abridge

##############################################
# Abridge transcription (partner/API access required)
##############################################
ABRIDGE_API_KEY=
ABRIDGE_BASE_URL=https://api.abridge.com
ABRIDGE_TRANSCRIBE_PATH=/v1/transcriptions
ABRIDGE_LANGUAGE=en
ABRIDGE_WORKFLOW_ID=
ABRIDGE_TRANSLATE_TO=

##############################################
# Nabla Core API transcription (OAuth client credentials or server access token)
##############################################
NABLA_BASE_URL=https://us.api.nabla.com
NABLA_TOKEN_PATH=/oauth/token
NABLA_TRANSCRIBE_PATH=/v1/core/server/transcribe
NABLA_API_VERSION=2025-05-21
NABLA_SPEECH_LOCALE=ENGLISH_US
NABLA_CLIENT_ID=
NABLA_PRIVATE_KEY=
NABLA_KEY_ID=
NABLA_SERVER_ACCESS_TOKEN=
NABLA_SPECIALTY=

##############################################
# AWS HealthScribe (recorded encounter batch workflow)
##############################################
AWS_HEALTHSCRIBE_REGION=us-east-1
AWS_HEALTHSCRIBE_INPUT_BUCKET=
AWS_HEALTHSCRIBE_OUTPUT_BUCKET=
AWS_HEALTHSCRIBE_DATA_ACCESS_ROLE_ARN=
AWS_HEALTHSCRIBE_INPUT_PREFIX=healthscribe/input
AWS_HEALTHSCRIBE_OUTPUT_PREFIX=healthscribe/output
AWS_HEALTHSCRIBE_NOTE_TEMPLATE=PHYSICAL_SOAP
AWS_HEALTHSCRIBE_POLL_INTERVAL_MS=5000
AWS_HEALTHSCRIBE_TIMEOUT_MS=300000
AWS_HEALTHSCRIBE_OUTPUT_KMS_KEY_ID=

##############################################
# Wispr Flow transcription (optional alternate provider)
##############################################
WISPR_FLOW_API_KEY=
WISPR_FLOW_BASE_URL=https://api.wisprflow.ai
WISPR_FLOW_TRANSCRIBE_PATH=/api/v1/voice-dictation/transcribe
WISPR_FLOW_LANGUAGE=en
WISPR_FLOW_WORKFLOW_ID=
WISPR_FLOW_TRANSLATE_TO=
